# NovaByte Environment Configuration Template
# Committed to version control — safe for all users.
# Contains ONLY defaults; never include secrets or placeholders.
# Copy to .env and auto-generate missing secrets, or fill in manually.

# Server
PORT=3003
HOST=127.0.0.1

# HTTPS — trust the local CA in Node.js
NODE_EXTRA_CA_CERTS=ca.crt

# Security — auto-generated on first run (64+ char hex strings)
SESSION_SECRET=
NBOSP_CRED_KEY=

# Rate Limiting (milliseconds, max requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS — must include https:// URLs
CORS_ORIGIN=https://localhost:3003,https://127.0.0.1:3003
